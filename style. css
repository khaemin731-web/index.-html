body{
    margin:0;
    font-family:Arial,sans-serif;
    background:linear-gradient(135deg,#0f172a,#1e3a8a);
    color:white;
    display:flex;
    justify-content:center;
    align-items:center;
    min-height:100vh;
    overflow:hidden;
}

.container{
    text-align:center;
    width:90%;
    max-width:500px;
    background:rgba(255,255,255,0.08);
    padding:30px;
    border-radius:20px;
    box-shadow:0 0 25px rgba(0,170,255,.4);
    backdrop-filter:blur(8px);
}

h1{
    font-size:2rem;
    animation:glow 2s infinite alternate;
}

@keyframes glow{
    from{
        text-shadow:0 0 10px #4fc3f7;
    }
    to{
        text-shadow:0 0 25px #ffffff;
    }
}

p{
    font-size:18px;
    line-height:1.6;
}

button{
    margin:12px;
    padding:12px 24px;
    font-size:18px;
    border:none;
    border-radius:30px;
    cursor:pointer;
    transition:.3s;
}

#yesBtn,
#startBtn{
    background:#22c55e;
    color:white;
}

#noBtn{
    background:#ef4444;
    color:white;
    position:relative;
}

button:hover{
    transform:scale(1.05);
}